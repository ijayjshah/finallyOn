# Supabase: use Session pooler URI (IPv4), NOT the direct db.*.supabase.co host (IPv6-only)
# Dashboard → Connect → Session pooler → URI
DATABASE_URL=postgresql://postgres.[project-ref]:password@aws-0-[region].pooler.supabase.com:5432/postgres

# API server (Render sets PORT automatically — use API_PORT locally)
API_PORT=8081

# Frontend URL(s) allowed by API CORS (required when frontend is on another domain)
# Use one origin, or comma-separated for multiple (e.g. prod + preview):
# CORS_ORIGIN=https://finallyon.in
# CORS_ORIGINS=https://finallyon.in,https://finallyon.onrender.com
CORS_ORIGIN=http://localhost:26163
WEB_ORIGIN=http://localhost:26163
BASE_PATH=/

# Vite dev proxy — defaults to http://localhost:${API_PORT} if unset
API_SERVER_URL=http://localhost:8081

# --- Frontend (Vercel) — set in Vercel dashboard, see artifacts/zariya/.env.example ---
# VITE_API_URL=https://your-api.onrender.com
# VITE_APP_URL=https://your-app.vercel.app

SESSION_SECRET=change-me-in-production

# Cloudinary — trust card image uploads (API server)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
