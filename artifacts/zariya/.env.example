# =============================================================================
# FinallyOn frontend (Vite) — copy to .env.local for local overrides
# On Vercel: add these in Project → Settings → Environment Variables
# =============================================================================

# Backend API (production / Vercel — required when API is on another host)
# No trailing slash. Do NOT include /api — the app adds that automatically.
# Example: https://finallyon-api.onrender.com
VITE_API_URL=

# Public URL of this frontend (optional — share links, canonical URL)
# Example: https://finallyon.vercel.app
VITE_APP_URL=

# --- Local dev only (used by vite.config.ts, not exposed to browser) ---
# Loaded from repo root ../../.env via `pnpm dev` — see root .env.example:
#   WEB_PORT=26163
#   API_SERVER_URL=http://localhost:8081
