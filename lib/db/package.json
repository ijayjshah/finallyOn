{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "check": "node ./scripts/check-connection.mjs",
    "push": "pnpm run check && drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "pnpm run check && drizzle-kit push --force --config ./drizzle.config.ts",
    "reset": "node --env-file=../../.env ./scripts/reset.mjs",
    "seed": "pnpm exec tsx --env-file=../../.env ./scripts/seed.ts",
    "backfill-slugs": "pnpm exec tsx --env-file=../../.env ./scripts/backfill-profile-slugs.ts"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "catalog:"
  }
}
